/*
 * nf-scrnaseq — Nextflow configuration
 *
 * The aligner chosen here is kb-python (kallisto|bustools). Rationale:
 *   - Tiny installation footprint (~50 MB vs STAR's ~2 GB index)
 *   - Pseudoalignment is fast enough for routine droplet scRNA-seq QC
 *   - First-class 10x v2/v3 + DropSeq chemistry presets
 * STARsolo remains the right call when you need allele-aware counts or
 * intron quantification across a deep cohort. To swap in STARsolo, replace
 * modules/align_count.nf — the channels into and out of the process are
 * already shaped to be aligner-agnostic.
 */

manifest {
    name            = 'nf-scrnaseq'
    author          = 'nf-scrnaseq contributors'
    description     = 'Single-cell RNA-seq pipeline: FASTQ -> QC + clustering + report'
    mainScript      = 'main.nf'
    nextflowVersion = '>=22.10.0'
    version         = '0.1.0'
}

// ----------------------------------------------------------
//  Default parameters (overridable on the CLI or per profile)
// ----------------------------------------------------------
params {
    // I/O
    samplesheet     = null
    outdir          = 'results'
    publish_mode    = 'copy'

    // Reference (kb-python)
    kb_index        = null
    t2g             = null
    chemistry       = '10xv3'        // kb -x argument

    // QC / filtering
    min_genes       = 200
    min_cells       = 3
    max_mito_pct    = 20.0
    doublet_thresh  = 0.25           // scrublet score cutoff
    // Fallback list of mitochondrial gene Ensembl IDs, used when the
    // reference (e.g. `kb ref -d human`) ships gene IDs as gene names so
    // the standard MT-/mt- symbol prefix returns 0 hits. Override with
    // your own TSV or set to null to disable the fallback.
    mt_gene_ids     = "${projectDir}/assets/mt_gene_ids.tsv"

    // Normalize / cluster
    n_top_genes     = 2000
    n_pcs           = 50
    n_neighbors     = 15
    resolution      = 0.8

    // MultiQC
    multiqc_config  = "${projectDir}/assets/multiqc_config.yml"

    // Misc
    help            = false
}

// ----------------------------------------------------------
//  Process defaults + per-stage resource hints
// ----------------------------------------------------------
process {
    cpus           = 2
    memory         = { 4.GB  * task.attempt }
    time           = { 2.h   * task.attempt }

    // Retry on OOM (137 = SIGKILL, often Linux OOM-killer; 143 = SIGTERM
    // when SLURM enforces a mem limit; 140 = some HPC schedulers).
    // task.attempt grows on retry, so memory and time scale with it.
    errorStrategy  = { task.exitStatus in [137,140,143] ? 'retry' : 'finish' }
    maxRetries     = 2

    publishDir = [
        path:    { "${params.outdir}/${meta?.id ?: 'pipeline'}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode:    params.publish_mode,
        saveAs:  { fn -> fn.equals('versions.yml') ? null : fn }
    ]

    withName: FASTQC            { cpus = 2; memory = { 2.GB  * task.attempt }; time = { 1.h * task.attempt } }
    withName: ALIGN_COUNT       { cpus = 8; memory = { 32.GB * task.attempt }; time = { 8.h * task.attempt } }
    withName: SCANPY_QC         { cpus = 2; memory = { 16.GB * task.attempt }; time = { 2.h * task.attempt } }
    withName: NORMALIZE_CLUSTER { cpus = 4; memory = { 24.GB * task.attempt }; time = { 4.h * task.attempt } }
    withName: REPORT            { cpus = 1; memory = { 4.GB  * task.attempt }; time = { 1.h * task.attempt } }
    withName: MULTIQC           { cpus = 1; memory = { 4.GB  * task.attempt }; time = { 1.h * task.attempt } }
}

// ----------------------------------------------------------
//  Reports + DAG
//  Inline ${params.outdir} so profile overrides land in the right place
//  (a `params.tracedir` intermediate gets resolved eagerly against the
//  default outdir before profile merging).
// ----------------------------------------------------------
timeline { enabled = true; file = "${params.outdir}/pipeline_info/timeline.html"; overwrite = true }
report   { enabled = true; file = "${params.outdir}/pipeline_info/report.html"  ; overwrite = true }
trace    { enabled = true; file = "${params.outdir}/pipeline_info/trace.txt"    ; overwrite = true }
dag      { enabled = true; file = "${params.outdir}/pipeline_info/dag.svg"      ; overwrite = true }

// ----------------------------------------------------------
//  Profiles
// ----------------------------------------------------------
profiles {
    standard  { includeConfig 'conf/standard.config'  }
    docker    { includeConfig 'conf/docker.config'    }
    slurm     { includeConfig 'conf/slurm.config'     }
    test      { includeConfig 'conf/test.config'      }
    codespace { includeConfig 'conf/codespace.config' }
}
