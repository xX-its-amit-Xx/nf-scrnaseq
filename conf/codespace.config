/*
 * codespace profile — right-sized for a standardLinux32gb GitHub Codespace
 * (4 cores, 16 GB RAM, 32 GB disk).
 *
 * Compose with -profile docker,codespace. The 16 GB Codespace can't
 * accommodate the production defaults in nextflow.config (which assume a
 * 32 GB+ workstation or HPC node).
 *
 * Sized assuming one process at a time on real 10x PBMC 1k data:
 *   - ALIGN_COUNT (kb-python, human index): ~10 GB peak
 *   - SCANPY_QC / NORMALIZE_CLUSTER: ~4 GB for ~1000 cells, fits 8 GB
 */

process {
    cpus   = 1
    memory = '2 GB'

    withName: FASTQC            { cpus = 2; memory = '2 GB'  ; time = '30m' }
    withName: ALIGN_COUNT       { cpus = 4; memory = '12 GB' ; time = '2h'  }
    withName: SCANPY_QC         { cpus = 2; memory = '12 GB' ; time = '1h'  }
    withName: NORMALIZE_CLUSTER { cpus = 2; memory = '10 GB' ; time = '1h'  }
    withName: REPORT            { cpus = 1; memory = '2 GB'  ; time = '30m' }
    withName: MULTIQC           { cpus = 1; memory = '2 GB'  ; time = '30m' }
}

executor {
    cpus   = 4
    memory = '14 GB'
}
