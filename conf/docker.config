/*
 * docker profile — single container ships every binary the pipeline needs
 * (FastQC, kb-python, scanpy + scrublet, MultiQC). Build with:
 *     docker build -t nf-scrnaseq:0.1.0 .
 */

docker {
    enabled    = true
    runOptions = '-u $(id -u):$(id -g)'
}

process {
    executor  = 'local'
    container = 'nf-scrnaseq:0.1.0'
}
