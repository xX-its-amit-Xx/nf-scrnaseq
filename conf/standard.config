/*
 * standard profile — local execution, expects FastQC, kb-python, scanpy,
 * scrublet, and multiqc to be on $PATH (conda env or system install).
 */

process {
    executor = 'local'
}

executor {
    cpus   = Runtime.runtime.availableProcessors()
    memory = '16 GB'
}

docker.enabled    = false
singularity.enabled = false
