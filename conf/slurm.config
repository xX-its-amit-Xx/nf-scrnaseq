/*
 * slurm profile — submit each process as a SLURM job. Tune the queue/partition
 * for your cluster via -c <your_overrides.config> or by editing here.
 */

process {
    executor      = 'slurm'
    queue         = 'standard'
    clusterOptions = '--export=ALL'
    scratch       = true

    // Heavier per-stage resources for real cohorts
    withName: ALIGN_COUNT       { cpus = 16; memory = '64 GB'; time = '12h' }
    withName: NORMALIZE_CLUSTER { cpus = 8 ; memory = '48 GB'; time = '6h'  }
}

executor {
    queueSize      = 50
    submitRateLimit = '10/min'
}

// SLURM clusters typically run via Singularity rather than Docker.
singularity {
    enabled    = true
    autoMounts = true
}

process.container = 'docker://nf-scrnaseq:0.1.0'
