/*
 * test profile — tiny bundled dataset for `nextflow run . -profile test`.
 *
 * To keep the git repo small, the test fastqs and kb-python index are
 * generated on the fly the first time you run the test profile (see
 * test/prepare_test_data.sh). After that they live in test/ and are reused.
 *
 * Resources are scaled down so this fits on a laptop (2 cores, 4 GB).
 * Filters are loosened so the toy dataset survives QC and reaches clustering.
 */

params {
    samplesheet     = "${projectDir}/test/samplesheet.csv"
    kb_index        = "${projectDir}/test/ref/index.idx"
    t2g             = "${projectDir}/test/ref/t2g.txt"
    chemistry       = '10xv3'

    // Toy data is small — loosen QC so cells survive
    min_genes       = 4
    min_cells       = 1
    max_mito_pct    = 100.0
    doublet_thresh  = 1.01     // disable doublet filtering on toy data
    n_top_genes     = 200
    n_pcs           = 10
    n_neighbors     = 5
    resolution      = 0.5

    outdir          = 'results_test'
}

// Groovy resolves the GStrings in `timeline { file = ... }` etc. eagerly
// against the base config's default outdir, so the report blocks land in
// `results/` instead of the test profile's `results_test/`. Re-set them
// here using the merged params.outdir value.
timeline.file = "${params.outdir}/pipeline_info/timeline.html"
report.file   = "${params.outdir}/pipeline_info/report.html"
trace.file    = "${params.outdir}/pipeline_info/trace.txt"
dag.file      = "${params.outdir}/pipeline_info/dag.svg"

process {
    cpus   = 1
    memory = '2 GB'
    time   = '30m'

    // Override every per-stage default from nextflow.config so the test
    // fits in a 16 GB Codespace.
    withName: FASTQC            { cpus = 1; memory = '1 GB'; time = '10m' }
    withName: ALIGN_COUNT       { cpus = 2; memory = '4 GB'; time = '30m' }
    withName: SCANPY_QC         { cpus = 1; memory = '2 GB'; time = '15m' }
    withName: NORMALIZE_CLUSTER { cpus = 1; memory = '2 GB'; time = '15m' }
    withName: REPORT            { cpus = 1; memory = '1 GB'; time = '10m' }
    withName: MULTIQC           { cpus = 1; memory = '1 GB'; time = '10m' }
}
