# Enforce LF on POSIX scripts and pipeline files so they run correctly when
# the repo is checked out on Linux (Codespaces, SLURM, CI).

*.sh        text eol=lf
*.py        text eol=lf
*.nf        text eol=lf
*.config    text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.html      text eol=lf
*.csv       text eol=lf
Dockerfile  text eol=lf
Makefile    text eol=lf
LICENSE     text eol=lf
.gitignore  text eol=lf
